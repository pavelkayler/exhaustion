# Server
HOST=0.0.0.0
PORT=8080

# Bybit real/mainnet trading credentials
# Used by Real broker and real manual test orders.
BYBIT_REST_URL=https://api.bybit.com
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_PRIVATE_WS_URL=wss://stream.bybit.com/v5/private
BYBIT_RECV_WINDOW=20000

# Bybit demo trading credentials
# Used by Demo broker and demo manual test orders.
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=
BYBIT_DEMO_REST_URL=https://api-demo.bybit.com

# CoinGlass
# Set COINGLASS_ENABLED=1 to allow CoinGlass usage in dataset receive / capability checks.
COINGLASS_ENABLED=1
COINGLASS_API_KEY=
COINGLASS_BASE_URL=https://open-api-v3.coinglass.com

# Optional debug flags
DEBUG_DATASET_TF=0
DEBUG_OPT_MARKETDATA=0
DEBUG_OPT_TRADES=0
