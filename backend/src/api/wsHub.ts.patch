### 5.1 `session.start` must honor optional selection payload

REPLACE THE BODY OF THE `session.start` BRANCH WITH:

      if (msg.action === "session.start") {
        try {
          const payloadRecord = readRpcRecord(msg.payload);
          const selectedBotId = String(payloadRecord.selectedBotId ?? "").trim();
          const selectedBotPresetId = String(payloadRecord.selectedBotPresetId ?? "").trim();
          const selectedExecutionProfileId = String(payloadRecord.selectedExecutionProfileId ?? "").trim();
          const hasSelections = Boolean(
            selectedBotId
            || selectedBotPresetId
            || selectedExecutionProfileId
          );

          if (hasSelections) {
            configStore.setSelections({
              ...(selectedBotId ? { selectedBotId } : {}),
              ...(selectedBotPresetId ? { selectedBotPresetId } : {}),
              ...(selectedExecutionProfileId ? { selectedExecutionProfileId } : {}),
            });
            configStore.persist();
            syncRuntimeStreamLifecycle();
          }

          const payload = await runtime.start({
            waitForReady: async ({ signal }) => {
              await awaitAllStreamsConnected({ timeoutMs: 15_000, signal });
            },
          });
          broadcastSnapshot();
          reply({
            type: "rpc_result",
            id: msg.id,
            action: msg.action,
            ok: true,
            payload,
          });
        } catch (error) {
          const payload = {
            ...buildRuntimeStatusPayload(),
            runtimeMessage: String((error as Error)?.message ?? error),
          };
          reply({
            type: "rpc_result",
            id: msg.id,
            action: msg.action,
            ok: false,
            error: payload.runtimeMessage,
            payload,
          });
        }
        return;
      }

### 5.2 ADD `manual_order.submit`

INSERT THIS NEW BRANCH BEFORE THE FINAL `rpc_action_not_supported` REPLY:

      if (msg.action === "manual_order.submit") {
        const payloadRecord = readRpcRecord(msg.payload);
        const symbol = String(payloadRecord.symbol ?? "").trim().toUpperCase();
