              message: "symbol_required",
            },
          });
          return;
        }

        const manualOrderArgs: {
          symbol: string;
          side: "LONG" | "SHORT";
          executionMode?: "demo" | "real";
          entryPrice?: number;
          tpPrice?: number;
          slPrice?: number;
          marginUSDT?: number;
          leverage?: number;
        } = {
          symbol,
          side,
          executionMode,
        };

        const entryPrice = readRpcNumber(payloadRecord.entryPrice);
        const tpPrice = readRpcNumber(payloadRecord.tpPrice);
